{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-o",
        "${fileBasenameNoExtension}",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "compile and run",
      "type": "shell",
      "command": "Get-Content \"${workspaceFolder}\\input.txt\" | & \".\\${fileBasenameNoExtension}.exe\" | Set-Content \"${workspaceFolder}\\output.txt\"",
      "dependsOn": "compile",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}

